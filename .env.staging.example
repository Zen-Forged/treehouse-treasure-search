# .env.staging.example
# Template for .env.staging.local — the local-only credentials file used by
# scripts that need to point at the staging Supabase project (migration replay,
# seed-staging, qa-walk against staging).
#
# Copy this file to .env.staging.local and fill in values from:
#   - Supabase dashboard → staging project → Settings → API
#   - Vercel dashboard → staging deployment URL (for NEXT_PUBLIC_SITE_URL)
#
# NEVER commit .env.staging.local — it is gitignored via the .env.*.local pattern.
# All keys without NEXT_PUBLIC_ prefix are server-only and must never appear in client code.
#
# For production credentials see .env.local (also gitignored).
# For Vercel deployment env wiring see docs/ladder-b-design.md §Session 54 Task 6.

# ── Supabase (staging project) ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=              # Staging project URL from Supabase dashboard
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # Publishable key (treehouse_search_staging_client)
SUPABASE_SERVICE_ROLE_KEY=             # Secret key (treehouse_search_staging_server) — SERVER ONLY

# ── Admin ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_EMAIL=               # Same admin email as prod; auth user id differs per project

# ── Site URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=                  # Staging Vercel URL, e.g. https://treehouse-treasure-search-git-staging-*.vercel.app

# ── Email (reuse prod Resend key — sends work the same) ────────────────────────
RESEND_API_KEY=                        # Copy from .env.local — Resend has no "staging" concept

# ── Other (copy from .env.local as needed for specific scripts) ────────────────
# ANTHROPIC_API_KEY=
# SERPAPI_KEY=
# APIFY_TOKEN=
# APIFY_ACTOR_ID=
# COMP_SOURCE=serpapi
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# ADMIN_PIN=
