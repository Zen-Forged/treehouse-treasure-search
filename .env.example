# .env.example
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
# All keys without NEXT_PUBLIC_ prefix are server-only and must never appear in client code.

# ── AI ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                     # Claude Vision + post caption generation

# ── Comp data ──────────────────────────────────────────────────────────────────
SERPAPI_KEY=                           # eBay sold comps via SerpAPI
APIFY_TOKEN=                           # Required only if COMP_SOURCE=apify
APIFY_ACTOR_ID=                        # Required only if COMP_SOURCE=apify
COMP_SOURCE=serpapi                    # "serpapi" (default) or "apify"

# ── Supabase (public — safe to expose to browser) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=              # Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # Anon/public JWT key from Supabase dashboard

# ── Supabase (server-only — never use NEXT_PUBLIC_ prefix) ────────────────────
SUPABASE_SERVICE_ROLE_KEY=             # Service role key — server API routes only

# ── Admin ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_EMAIL=               # Admin user email (used for magic link + isAdmin check)
ADMIN_PIN=                             # Server-only PIN for admin login route
